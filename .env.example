# Either set CLOUDINARY_URL (e.g. cloudinary://key:secret@cloud_name) or the three vars below:
# CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: folder containing model_sub, model_top, model_bottom, model_shoes (default: ./models-saved/models)
# MODELS_DIR=

# Optional: local upload directory for API (default: uploads_images)
# UPLOAD_ROOT=

# Comma-separated origins for browser clients, or * for any (dev only)
# ALLOW_ORIGINS=https://your-frontend.com,http://localhost:3000
